#!/usr/bin/env python3
"""secrets — sops/age-backed env var manager.

Surfaces grouped, encrypted env-files from $SECRETS_DIR
(default: ~/src/dotfiles-private/secrets/) without writing plaintext to disk.

Subcommands:
  list                          available buckets
  edit <bucket>                 open in $EDITOR; sops re-encrypts on save
  export <bucket>...            print `export VAR=value` lines (for direnv / eval)
  run <bucket>... -- <cmd>...   exec cmd with vars in env; never writes disk
  which <varname>               which bucket(s) define this var
  rotate <bucket>               re-encrypt with current .sops.yaml recipients
  status                        sanity-check tooling and key files

Files are <bucket>.env.enc; bucket name is <bucket>.
"""
from __future__ import annotations

import argparse
import os
import shlex
import subprocess
import sys
from pathlib import Path
from shutil import which

DEFAULT_DIR = Path.home() / "src" / "dotfiles-private" / "secrets"


def secrets_dir() -> Path:
    p = Path(os.environ.get("SECRETS_DIR", DEFAULT_DIR))
    if not p.is_dir():
        sys.exit(f"secrets: SECRETS_DIR not found: {p}")
    return p


def bucket_path(name: str) -> Path:
    p = secrets_dir() / f"{name}.env.enc"
    if not p.is_file():
        sys.exit(f"secrets: bucket not found: {name} (looked for {p})")
    return p


def decrypt(path: Path) -> str:
    # --input-type/--output-type dotenv: ciphertext file uses .env.enc suffix,
    # which sops treats as unknown ('.enc' is the last extension) and defaults
    # to JSON. Force dotenv handling on both ends.
    r = subprocess.run(
        ["sops", "-d", "--input-type", "dotenv", "--output-type", "dotenv", str(path)],
        capture_output=True, text=True,
    )
    if r.returncode != 0:
        sys.exit(f"secrets: sops -d {path} failed:\n{r.stderr.rstrip()}")
    return r.stdout


def parse_env(text: str) -> dict[str, str]:
    """Parse minimal KEY=value env file syntax. No interpolation."""
    out: dict[str, str] = {}
    for raw in text.splitlines():
        ln = raw.strip()
        if not ln or ln.startswith("#") or "=" not in ln:
            continue
        k, _, v = ln.partition("=")
        k = k.strip()
        v = v.strip()
        if len(v) >= 2 and v[0] == v[-1] and v[0] in ("'", '"'):
            v = v[1:-1]
        out[k] = v
    return out


def cmd_list(args):
    for f in sorted(secrets_dir().glob("*.env.enc")):
        print(f.name.removesuffix(".env.enc"))


def cmd_edit(args):
    os.execvp("sops", ["sops", "--input-type", "dotenv", "--output-type", "dotenv",
                       str(bucket_path(args.bucket))])


def cmd_export(args):
    seen: set[str] = set()
    for name in args.buckets:
        for k, v in parse_env(decrypt(bucket_path(name))).items():
            if k in seen:
                print(f"# secrets: {k} already exported by an earlier bucket; skipping",
                      file=sys.stderr)
                continue
            seen.add(k)
            print(f"export {k}={shlex.quote(v)}")


def cmd_run(args):
    if not args.cmd:
        sys.exit("secrets run: missing -- <command>")
    env = os.environ.copy()
    for name in args.buckets:
        env.update(parse_env(decrypt(bucket_path(name))))
    os.execvpe(args.cmd[0], args.cmd, env)


def cmd_which(args):
    hits = []
    for f in sorted(secrets_dir().glob("*.env.enc")):
        if args.varname in parse_env(decrypt(f)):
            hits.append(f.name.removesuffix(".env.enc"))
    if not hits:
        sys.exit(f"secrets: {args.varname} not found in any bucket")
    for h in hits:
        print(h)


def cmd_rotate(args):
    os.execvp("sops", ["sops", "updatekeys",
                       "--input-type", "dotenv", "--output-type", "dotenv",
                       str(bucket_path(args.bucket))])


def cmd_status(args):
    ok = True
    for tool in ("sops", "age"):
        if not which(tool):
            print(f"missing tool: {tool}", file=sys.stderr)
            ok = False
    d = Path(os.environ.get("SECRETS_DIR", DEFAULT_DIR))
    if not d.is_dir():
        print(f"missing dir: {d}", file=sys.stderr)
        ok = False
    elif not (d / ".sops.yaml").is_file():
        print(f"missing: {d / '.sops.yaml'}", file=sys.stderr)
        ok = False
    age_keys = Path(os.environ.get("SOPS_AGE_KEY_FILE",
                    Path.home() / ".config" / "sops" / "age" / "keys.txt"))
    age_yubi = Path.home() / ".config" / "age" / "identities.txt"
    if not age_keys.is_file() and not age_yubi.is_file():
        print(f"missing age identity ({age_keys} or {age_yubi})", file=sys.stderr)
        ok = False
    if ok:
        print("ok")
    sys.exit(0 if ok else 1)


def main():
    argv = sys.argv[1:]
    cmd_args: list[str] = []
    if "--" in argv:
        i = argv.index("--")
        cmd_args = argv[i + 1:]
        argv = argv[:i]

    p = argparse.ArgumentParser(prog="secrets",
                                description=__doc__.split("\n", 2)[0])
    sub = p.add_subparsers(dest="cmd", required=True)
    sub.add_parser("list").set_defaults(fn=cmd_list)
    e = sub.add_parser("edit"); e.add_argument("bucket"); e.set_defaults(fn=cmd_edit)
    x = sub.add_parser("export"); x.add_argument("buckets", nargs="+"); x.set_defaults(fn=cmd_export)
    r = sub.add_parser("run"); r.add_argument("buckets", nargs="+"); r.set_defaults(fn=cmd_run)
    w = sub.add_parser("which"); w.add_argument("varname"); w.set_defaults(fn=cmd_which)
    rt = sub.add_parser("rotate"); rt.add_argument("bucket"); rt.set_defaults(fn=cmd_rotate)
    sub.add_parser("status").set_defaults(fn=cmd_status)

    args = p.parse_args(argv)
    args.cmd_args = cmd_args
    if args.cmd == "run":
        args.cmd = cmd_args
    args.fn(args)


if __name__ == "__main__":
    main()
